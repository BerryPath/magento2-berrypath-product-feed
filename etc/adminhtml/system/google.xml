<?xml version="1.0"?>
<include xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_include.xsd">
    <group id="google" translate="label" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
        <label>Google Shopping</label>
        <field id="condition" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Condition</label>
            <comment>Used when Feed type is Google Shopping RSS 2.0.</comment>
            <source_model>BerryPath\ProductFeed\Model\Config\Source\ProductCondition</source_model>
        </field>
        <field id="include_shipping" translate="label comment" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Include shipping</label>
            <comment>Add a g:shipping node to each Google Shopping item when country and price are configured.</comment>
            <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
        </field>
        <field id="shipping_country" translate="label comment" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Shipping country</label>
            <comment>Two-letter country code, for example NL.</comment>
        </field>
        <field id="shipping_service" translate="label comment" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Shipping service</label>
            <comment>Optional shipping service name, for example Standard.</comment>
        </field>
        <field id="shipping_price" translate="label comment" type="text" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Shipping price</label>
            <comment>Decimal amount without currency. The feed appends the store currency, for example 4.95 EUR.</comment>
        </field>
    </group>
</include>
